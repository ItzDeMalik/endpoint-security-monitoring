<!-- ============================================================ -->
<!--   Custom Wazuh Detection Rules - Internee.pk               -->
<!--   File: /var/ossec/etc/rules/custom-rules.xml              -->
<!--   These rules extend Wazuh's built-in detection capability -->
<!-- ============================================================ -->

<group name="internee_custom,">

  <!-- ==================== FILE INTEGRITY MONITORING ==================== -->

  <!-- Rule 100001: Critical file modified -->
  <rule id="100001" level="10">
    <if_sid>550</if_sid>
    <match>C:\Windows\System32</match>
    <description>FIM Alert: Critical Windows system file modified - $(file)</description>
    <group>fim,system_integrity,</group>
    <mitre>
      <id>T1565.001</id> <!-- Stored Data Manipulation -->
    </mitre>
  </rule>

  <!-- ==================== BRUTE FORCE DETECTION ==================== -->

  <!-- Rule 100002: Multiple failed logins - potential brute force -->
  <rule id="100002" level="12" frequency="5" timeframe="60">
    <if_matched_sid>60122</if_matched_sid> <!-- Windows failed login -->
    <same_srcip/>
    <description>Brute Force Detected: $(5) failed login attempts in 60 seconds from $(srcip)</description>
    <group>brute_force,authentication_failure,</group>
    <mitre>
      <id>T1110</id> <!-- Brute Force -->
    </mitre>
  </rule>

  <!-- ==================== PRIVILEGE ESCALATION ==================== -->

  <!-- Rule 100003: Non-admin user added to privileged group -->
  <rule id="100003" level="12">
    <if_sid>60144</if_sid> <!-- User added to security group -->
    <field name="win.eventdata.targetUserName" type="pcre2">(?i)(Administrators|Domain Admins|Enterprise Admins)</field>
    <description>Privilege Escalation: User added to privileged group - $(win.eventdata.subjectUserName) added $(win.eventdata.memberName)</description>
    <group>privilege_escalation,account_management,</group>
    <mitre>
      <id>T1078</id> <!-- Valid Accounts -->
    </mitre>
  </rule>

  <!-- ==================== SUSPICIOUS POWERSHELL ==================== -->

  <!-- Rule 100004: Encoded/obfuscated PowerShell execution -->
  <rule id="100004" level="13">
    <if_sid>91801</if_sid> <!-- Sysmon process create -->
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-enc|-encodedcommand|-nop|-noprofile|-w hidden|downloadstring|iex |invoke-expression)</field>
    <description>Suspicious PowerShell: Obfuscated or download cradle detected - $(win.eventdata.commandLine)</description>
    <group>suspicious_powershell,malware,</group>
    <mitre>
      <id>T1059.001</id> <!-- PowerShell -->
    </mitre>
  </rule>

  <!-- ==================== MALWARE HASH DETECTION ==================== -->

  <!-- Rule 100005: Known malware hash detected (fed from MalwareBazaar) -->
  <rule id="100005" level="15">
    <if_sid>91801</if_sid>
    <list field="win.eventdata.hashes" lookup="match_key">etc/lists/malware-hashes</list>
    <description>CRITICAL: Known malware hash detected on endpoint - $(win.eventdata.image)</description>
    <group>malware,threat_intel,</group>
    <mitre>
      <id>T1204</id> <!-- User Execution -->
    </mitre>
  </rule>

  <!-- ==================== CREDENTIAL DUMPING ==================== -->

  <!-- Rule 100006: LSASS memory access - potential credential dumping -->
  <rule id="100006" level="14">
    <if_sid>91810</if_sid> <!-- Sysmon process access -->
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">0x1010|0x1410|0x147a|0x143a</field>
    <description>Credential Dumping Attempt: LSASS memory accessed by $(win.eventdata.sourceImage)</description>
    <group>credential_dumping,</group>
    <mitre>
      <id>T1003.001</id> <!-- LSASS Memory -->
    </mitre>
  </rule>

  <!-- ==================== LATERAL MOVEMENT ==================== -->

  <!-- Rule 100007: Suspicious remote connection attempt -->
  <rule id="100007" level="11">
    <if_sid>91803</if_sid> <!-- Sysmon network connection -->
    <field name="win.eventdata.image" type="pcre2">(?i)(cmd\.exe|powershell\.exe|wscript\.exe|cscript\.exe)</field>
    <field name="win.eventdata.destinationPort" type="pcre2">445|135|3389|5985|5986</field>
    <description>Lateral Movement Suspected: $(win.eventdata.image) connecting to $(win.eventdata.destinationIp):$(win.eventdata.destinationPort)</description>
    <group>lateral_movement,</group>
    <mitre>
      <id>T1021</id> <!-- Remote Services -->
    </mitre>
  </rule>

  <!-- ==================== PERSISTENCE MECHANISMS ==================== -->

  <!-- Rule 100008: New service created (common persistence technique) -->
  <rule id="100008" level="11">
    <if_sid>60010</if_sid> <!-- Windows service installed -->
    <description>Persistence: New Windows service installed - $(win.eventdata.serviceName)</description>
    <group>persistence,</group>
    <mitre>
      <id>T1543.003</id> <!-- Windows Service -->
    </mitre>
  </rule>

  <!-- Rule 100009: Registry run key modification -->
  <rule id="100009" level="10">
    <if_sid>91814</if_sid> <!-- Sysmon registry set value -->
    <field name="win.eventdata.targetObject" type="pcre2">(?i)(CurrentVersion\\Run|CurrentVersion\\RunOnce)</field>
    <description>Persistence: Registry Run key modified - $(win.eventdata.targetObject)</description>
    <group>persistence,registry,</group>
    <mitre>
      <id>T1547.001</id> <!-- Registry Run Keys -->
    </mitre>
  </rule>

  <!-- ==================== DATA EXFILTRATION ==================== -->

  <!-- Rule 100010: Large outbound data transfer -->
  <rule id="100010" level="10">
    <if_sid>91803</if_sid>
    <field name="win.eventdata.destinationPort" type="pcre2">^(?!80$|443$|53$).*</field>
    <field name="data.srcbytes" type="pcre2">^[1-9][0-9]{7,}</field> <!-- > 10MB -->
    <description>Possible Data Exfiltration: Large transfer ($(data.srcbytes) bytes) to $(win.eventdata.destinationIp)</description>
    <group>data_exfiltration,</group>
    <mitre>
      <id>T1041</id> <!-- Exfiltration Over C2 Channel -->
    </mitre>
  </rule>

</group>
